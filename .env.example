# ── Copy this file to .env.local and fill in real values. ──────────────
# .env.local is gitignored; never commit real secrets.

# Shared PIN everyone uses to unlock the app
APP_PIN=1234

# From Google AI Studio (https://aistudio.google.com) → Get API key.
# The key may start with "AIza" or "AQ." — either is fine. Paste the whole thing.
GEMINI_API_KEY=your-gemini-api-key

# Optional: override the model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# From the service account JSON key file: "client_email" and "private_key".
# Keep the private key on ONE line with literal \n sequences, wrapped in quotes,
# exactly as it appears inside the JSON file.
GOOGLE_SERVICE_ACCOUNT_EMAIL=expense-bot@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# The long ID in the sheet URL: https://docs.google.com/spreadsheets/d/<THIS PART>/edit
GOOGLE_SHEET_ID=1AbC...

# Tab name inside the spreadsheet (default: Sheet1)
SHEET_NAME=Sheet1

# Everyone sharing this tracker — list every name separated by commas.
# Add as many as you like; the first name is the default selection.
PEOPLE=Alex,Sam
# (Legacy alternative, still supported: PERSON_1=Alex, PERSON_2=Sam, PERSON_3=…)
